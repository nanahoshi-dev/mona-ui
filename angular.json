{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "mona-ui": {
            "projectType": "library",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "none",
                    "changeDetection": "OnPush"
                }
            },
            "root": "projects/mona-ui",
            "sourceRoot": "projects/mona-ui/src",
            "prefix": "mona",
            "architect": {
                "build": {
                    "builder": "@angular/build:ng-packagr",
                    "options": {
                        "project": "projects/mona-ui/ng-package.json"
                    },
                    "configurations": {
                        "production": {
                            "tsConfig": "projects/mona-ui/tsconfig.lib.prod.json"
                        },
                        "development": {
                            "tsConfig": "projects/mona-ui/tsconfig.lib.json"
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "setupFiles": ["./test-setup.ts"]
                    }
                }
            }
        },
        "mona-ui-tester": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "none",
                    "changeDetection": "OnPush"
                }
            },
            "root": "projects/mona-ui-tester",
            "sourceRoot": "projects/mona-ui-tester/src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular/build:application",
                    "options": {
                        "outputPath": {
                            "base": "dist/mona-ui-tester"
                        },
                        "index": "projects/mona-ui-tester/src/index.html",
                        "polyfills": ["projects/mona-ui-tester/src/polyfills.ts"],
                        "tsConfig": "projects/mona-ui-tester/tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "assets": ["projects/mona-ui-tester/src/favicon.ico", "projects/mona-ui-tester/src/assets"],
                        "stylePreprocessorOptions": {
                            "includePaths": [""]
                        },
                        "styles": [
                            "node_modules/@fortawesome/fontawesome-free/css/all.css",
                            "node_modules/highlight.js/styles/nord.min.css",
                            "projects/mona-ui-tester/src/styles.css"
                        ],
                        "scripts": ["node_modules/@fortawesome/fontawesome-free/js/all.js"],
                        "browser": "projects/mona-ui-tester/src/main.ts"
                    },
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kb",
                                    "maximumError": "1mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "2kb",
                                    "maximumError": "4kb"
                                }
                            ],
                            "fileReplacements": [
                                {
                                    "replace": "projects/mona-ui-tester/src/environments/environment.ts",
                                    "with": "projects/mona-ui-tester/src/environments/environment.prod.ts"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "namedChunks": true
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular/build:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "mona-ui-tester:build:production"
                        },
                        "development": {
                            "buildTarget": "mona-ui-tester:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular/build:extract-i18n",
                    "options": {
                        "buildTarget": "mona-ui-tester:build"
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "setupFiles": ["./test-setup.ts"]
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": false
    },
    "schematics": {
        "@schematics/angular:component": {
            "type": "component"
        },
        "@schematics/angular:directive": {
            "type": "directive"
        },
        "@schematics/angular:service": {
            "type": "service"
        },
        "@schematics/angular:guard": {
            "typeSeparator": "."
        },
        "@schematics/angular:interceptor": {
            "typeSeparator": "."
        },
        "@schematics/angular:module": {
            "typeSeparator": "."
        },
        "@schematics/angular:pipe": {
            "typeSeparator": "."
        },
        "@schematics/angular:resolver": {
            "typeSeparator": "."
        }
    }
}
