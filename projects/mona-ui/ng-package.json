{
    "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
    "dest": "../../dist/mona-ui",
    "allowedNonPeerDependencies": [
        "^@lucide/angular$",
        "^@mirei/ts-collections$",
        "^class-variance-authority$",
        "^culori$",
        "^luxon$",
        "^remixicon$",
        "^tailwind-merge$",
        "^uuid$"
    ],
    "lib": {
        "entryFile": "src/public-api.ts"
    },
    "assets": [
        {
            "input": "src/styles",
            "glob": "**/*.scss",
            "output": "styles"
        }
    ]
}
