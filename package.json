{
    "name": "@mirei/mona-ui",
    "version": "3.0.1",
    "description": "A very light Angular UI framework",
    "main": "dist/mona-ui/fesm2022/mona-ui.mjs",
    "exports": {
        ".": {
            "types": "./dist/mona-ui/index.d.ts",
            "esm2022": "./dist/mona-ui/esm2022/mona-ui.mjs",
            "esm": "./dist/mona-ui/esm2022/mona-ui.mjs",
            "default": "./dist/mona-ui/fesm2022/mona-ui.mjs"
        }
    },
    "typings": "dist/mona-ui/index.d.ts",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "prebuild": "npm run build:metadata",
        "prewatch": "npm run build:metadata",
        "build": "npm run build:prod",
        "build:dev": "ng build mona-ui --configuration development",
        "build:prod": "ng build mona-ui --configuration production",
        "build:watch": "ng build mona-ui --watch --configuration development",
        "build:metadata": "tsx projects/mona-ui-tester/scripts/extract-metadata.ts",
        "watch": "ng build mona-ui --watch --configuration development",
        "test:lib": "ng test mona-ui --code-coverage --watch=false",
        "test:lib:watch": "ng test mona-ui --code-coverage --watch",
        "test:app": "ng test mona-ui-tester"
    },
    "author": "Nanahoshi",
    "files": [
        "dist",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hoshixlily/mona-ui"
    },
    "publishConfig": {
        "access": "public"
    },
    "workspaces": [
        "projects/*"
    ],
    "release": {
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/npm",
            "@semantic-release/git",
            "@semantic-release/github"
        ],
        "branches": [
            "main"
        ]
    },
    "dependencies": {
        "@angular/animations": "^21.0.0",
        "@angular/cdk": "^20.0.5",
        "@angular/common": "^21.0.0",
        "@angular/compiler": "^21.0.0",
        "@angular/core": "^21.0.0",
        "@angular/forms": "^21.0.0",
        "@angular/platform-browser": "^21.0.0",
        "@angular/platform-browser-dynamic": "^21.0.0",
        "@angular/router": "^21.0.0",
        "@fortawesome/angular-fontawesome": "^2.0.1",
        "@fortawesome/fontawesome-svg-core": "^6.7.2",
        "@fortawesome/free-solid-svg-icons": "^6.7.2",
        "@mirei/ts-collections": "^17.0.0",
        "@tailwindcss/postcss": "^4.1.11",
        "@tiptap/core": "^2.12.0",
        "@tiptap/extension-color": "^2.12.0",
        "@tiptap/extension-font-family": "^2.12.0",
        "@tiptap/extension-highlight": "^2.12.0",
        "@tiptap/extension-image": "^2.12.0",
        "@tiptap/extension-link": "^2.12.0",
        "@tiptap/extension-subscript": "^2.12.0",
        "@tiptap/extension-superscript": "^2.12.0",
        "@tiptap/extension-table": "^2.12.0",
        "@tiptap/extension-table-cell": "^2.12.0",
        "@tiptap/extension-table-header": "^2.12.0",
        "@tiptap/extension-table-row": "^2.12.0",
        "@tiptap/extension-task-item": "^2.12.0",
        "@tiptap/extension-task-list": "^2.12.0",
        "@tiptap/extension-text-align": "^2.12.0",
        "@tiptap/extension-text-style": "^2.12.0",
        "@tiptap/extension-underline": "^2.12.0",
        "@tiptap/pm": "^2.12.0",
        "@tiptap/starter-kit": "^2.12.0",
        "class-variance-authority": "^0.7.1",
        "highlight.js": "^11.11.1",
        "lucide-angular": "^0.525.0",
        "luxon": "^3.6.1",
        "postcss": "^8.5.6",
        "prosemirror-state": "^1.4.3",
        "remixicon": "^4.6.0",
        "rxjs": "~7.8.1",
        "tailwind-merge": "^3.3.1",
        "tailwindcss": "^4.1.11",
        "tslib": "^2.8.1",
        "uuid": "^11.1.0",
        "zone.js": "~0.15.1"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^20.1.1",
        "@angular-eslint/eslint-plugin": "^20.1.1",
        "@angular-eslint/eslint-plugin-template": "^20.1.1",
        "@angular-eslint/schematics": "^20.1.1",
        "@angular-eslint/template-parser": "^20.1.1",
        "@angular/build": "^21.0.0",
        "@angular/cli": "^21.0.0",
        "@angular/compiler-cli": "^21.0.0",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.30.1",
        "@fortawesome/fontawesome-free": "^6.7.2",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/highlightjs": "^10.1.0",
        "@types/jasmine": "~5.1.8",
        "@types/luxon": "^3.6.2",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.35.1",
        "@typescript-eslint/parser": "^8.35.1",
        "eslint": "^9.30.1",
        "jasmine-core": "~5.8.0",
        "karma": "~6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.1",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "ng-packagr": "^21.0.0",
        "postcss": "^8.5.3",
        "prettier": "^3.6.2",
        "ts-morph": "^26.0.0",
        "tsx": "^4.20.3",
        "typescript": "~5.9.3"
    }
}