{
    "name": "@mirei/mona-ui",
    "version": "3.0.1",
    "description": "A very light Angular UI framework",
    "main": "dist/mona-ui/fesm2022/mona-ui.mjs",
    "exports": {
        "./package.json": {
            "default": "./package.json"
        },
        ".": {
            "types": "./dist/mona-ui/types/mona-ui.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui.mjs"
        },
        "./button": {
            "types": "./dist/mona-ui/types/mona-ui-button.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-button.mjs"
        },
        "./auto-complete": {
            "types": "./dist/mona-ui/types/mona-ui-auto-complete.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-auto-complete.mjs"
        },
        "./button-group": {
            "types": "./dist/mona-ui/types/mona-ui-button-group.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-button-group.mjs"
        },
        "./calendar": {
            "types": "./dist/mona-ui/types/mona-ui-calendar.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-calendar.mjs"
        },
        "./chip": {
            "types": "./dist/mona-ui/types/mona-ui-chip.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-chip.mjs"
        },
        "./combo-box": {
            "types": "./dist/mona-ui/types/mona-ui-combo-box.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-combo-box.mjs"
        },
        "./date-picker": {
            "types": "./dist/mona-ui/types/mona-ui-date-picker.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-date-picker.mjs"
        },
        "./datetime-picker": {
            "types": "./dist/mona-ui/types/mona-ui-datetime-picker.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-datetime-picker.mjs"
        },
        "./dialog": {
            "types": "./dist/mona-ui/types/mona-ui-dialog.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-dialog.mjs"
        },
        "./drop-down-list": {
            "types": "./dist/mona-ui/types/mona-ui-drop-down-list.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-drop-down-list.mjs"
        },
        "./drop-down-tree": {
            "types": "./dist/mona-ui/types/mona-ui-drop-down-tree.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-drop-down-tree.mjs"
        },
        "./dropdown-button": {
            "types": "./dist/mona-ui/types/mona-ui-dropdown-button.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-dropdown-button.mjs"
        },
        "./multi-select": {
            "types": "./dist/mona-ui/types/mona-ui-multi-select.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-multi-select.mjs"
        },
        "./split-button": {
            "types": "./dist/mona-ui/types/mona-ui-split-button.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-split-button.mjs"
        },
        "./time-picker": {
            "types": "./dist/mona-ui/types/mona-ui-time-picker.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-time-picker.mjs"
        },
        "./time-selector": {
            "types": "./dist/mona-ui/types/mona-ui-time-selector.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-time-selector.mjs"
        },
        "./window": {
            "types": "./dist/mona-ui/types/mona-ui-window.d.ts",
            "default": "./dist/mona-ui/fesm2022/mona-ui-window.mjs"
        }
    },
    "typings": "dist/mona-ui/types/mona-ui.d.ts",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "prebuild": "npm run build:metadata",
        "prewatch": "npm run build:metadata",
        "build": "npm run build:prod",
        "build:dev": "ng build mona-ui --configuration development",
        "build:prod": "ng build mona-ui --configuration production",
        "build:watch": "ng build mona-ui --watch --configuration development",
        "build:metadata": "tsx projects/mona-ui-tester/scripts/extract-metadata.ts",
        "watch": "ng build mona-ui --watch --configuration development",
        "test:lib": "ng test mona-ui --watch=false",
        "test:lib:watch": "ng test mona-ui --code-coverage --watch",
        "test:app": "ng test mona-ui-tester"
    },
    "author": "Nanahoshi",
    "files": [
        "dist",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hoshixlily/mona-ui"
    },
    "publishConfig": {
        "access": "public"
    },
    "workspaces": [
        "projects/*"
    ],
    "release": {
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/npm",
            "@semantic-release/git",
            "@semantic-release/github"
        ],
        "branches": [
            "main"
        ]
    },
    "dependencies": {
        "@angular/cdk": "^22.0.1",
        "@angular/common": "^22.0.1",
        "@angular/compiler": "^22.0.1",
        "@angular/core": "^22.0.1",
        "@angular/forms": "^22.0.1",
        "@angular/platform-browser": "^22.0.1",
        "@angular/platform-browser-dynamic": "^22.0.1",
        "@angular/router": "^22.0.1",
        "@fortawesome/angular-fontawesome": "^5.0.0",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@lucide/angular": "^1.21.0",
        "@mirei/ts-collections": "^17.5.6",
        "@tailwindcss/postcss": "^4.3.1",
        "@tiptap/core": "^3.26.1",
        "@tiptap/extension-color": "^3.26.1",
        "@tiptap/extension-font-family": "^3.26.1",
        "@tiptap/extension-highlight": "^3.26.1",
        "@tiptap/extension-image": "^3.26.1",
        "@tiptap/extension-subscript": "^3.26.1",
        "@tiptap/extension-superscript": "^3.26.1",
        "@tiptap/extension-table": "^3.26.1",
        "@tiptap/extension-table-cell": "^3.26.1",
        "@tiptap/extension-table-header": "^3.26.1",
        "@tiptap/extension-table-row": "^3.26.1",
        "@tiptap/extension-task-item": "^3.26.1",
        "@tiptap/extension-task-list": "^3.26.1",
        "@tiptap/extension-text-align": "^3.26.1",
        "@tiptap/extension-text-style": "^3.26.1",
        "@tiptap/pm": "^3.26.1",
        "@tiptap/starter-kit": "^3.26.1",
        "class-variance-authority": "^0.7.1",
        "highlight.js": "^11.11.1",
        "luxon": "^3.7.2",
        "marked": "^18.0.5",
        "marked-highlight": "^2.2.4",
        "ngx-markdown": "^22.0.0",
        "postcss": "^8.5.15",
        "prosemirror-state": "^1.4.4",
        "remixicon": "^4.9.1",
        "rxjs": "~7.8.2",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.1",
        "tslib": "^2.8.1",
        "uuid": "^14.0.0",
        "zone.js": "~0.16.2"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^22.0.0",
        "@angular-eslint/eslint-plugin": "^22.0.0",
        "@angular-eslint/eslint-plugin-template": "^22.0.0",
        "@angular-eslint/schematics": "^22.0.0",
        "@angular-eslint/template-parser": "^22.0.0",
        "@angular/build": "^22.0.1",
        "@angular/cli": "^22.0.1",
        "@angular/compiler-cli": "^22.0.1",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@fortawesome/fontawesome-free": "^7.2.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/highlightjs": "^10.1.0",
        "@types/jasmine": "~6.0.0",
        "@types/luxon": "^3.7.1",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "@vitest/coverage-v8": "^4.1.8",
        "@vitest/ui": "^4.1.8",
        "eslint": "^10.5.0",
        "jasmine-core": "~6.3.0",
        "jsdom": "^29.1.1",
        "ng-packagr": "^22.0.0",
        "postcss": "^8.5.15",
        "prettier": "^3.8.4",
        "ts-morph": "^28.0.0",
        "tsx": "^4.22.4",
        "typescript": "~6.0.3",
        "vitest": "^4.1.8"
    }
