{
    "name": "@mirei/mona-ui",
    "version": "3.0.1",
    "description": "A very light Angular UI framework",
    "main": "dist/mona-ui/fesm2022/mona-ui.mjs",
    "exports": {
        ".": {
            "types": "./dist/mona-ui/index.d.ts",
            "esm2022": "./dist/mona-ui/esm2022/mona-ui.mjs",
            "esm": "./dist/mona-ui/esm2022/mona-ui.mjs",
            "default": "./dist/mona-ui/fesm2022/mona-ui.mjs"
        }
    },
    "typings": "dist/mona-ui/index.d.ts",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "prebuild": "npm run build:metadata",
        "prewatch": "npm run build:metadata",
        "build": "npm run build:prod",
        "build:dev": "ng build mona-ui --configuration development",
        "build:prod": "ng build mona-ui --configuration production",
        "build:watch": "ng build mona-ui --watch --configuration development",
        "build:metadata": "tsx projects/mona-ui-tester/scripts/extract-metadata.ts",
        "watch": "ng build mona-ui --watch --configuration development",
        "test:lib": "ng test mona-ui --code-coverage --watch=false",
        "test:lib:watch": "ng test mona-ui --code-coverage --watch",
        "test:app": "ng test mona-ui-tester"
    },
    "author": "Nanahoshi",
    "files": [
        "dist",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hoshixlily/mona-ui"
    },
    "publishConfig": {
        "access": "public"
    },
    "workspaces": [
        "projects/*"
    ],
    "release": {
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/npm",
            "@semantic-release/git",
            "@semantic-release/github"
        ],
        "branches": [
            "main"
        ]
    },
    "dependencies": {
        "@angular/animations": "^21.0.3",
        "@angular/cdk": "^21.0.2",
        "@angular/common": "^21.0.3",
        "@angular/compiler": "^21.0.3",
        "@angular/core": "^21.0.3",
        "@angular/forms": "^21.0.3",
        "@angular/platform-browser": "^21.0.3",
        "@angular/platform-browser-dynamic": "^21.0.3",
        "@angular/router": "^21.0.3",
        "@fortawesome/angular-fontawesome": "^4.0.0",
        "@fortawesome/fontawesome-svg-core": "^7.1.0",
        "@fortawesome/free-solid-svg-icons": "^7.1.0",
        "@mirei/ts-collections": "^17.3.0",
        "@tailwindcss/postcss": "^4.1.17",
        "@tiptap/core": "^3.11.0",
        "@tiptap/extension-color": "^3.11.0",
        "@tiptap/extension-font-family": "^3.11.0",
        "@tiptap/extension-highlight": "^3.11.0",
        "@tiptap/extension-image": "^3.11.0",
        "@tiptap/extension-subscript": "^3.11.0",
        "@tiptap/extension-superscript": "^3.11.0",
        "@tiptap/extension-table": "^3.11.0",
        "@tiptap/extension-table-cell": "^3.11.0",
        "@tiptap/extension-table-header": "^3.11.0",
        "@tiptap/extension-table-row": "^3.11.0",
        "@tiptap/extension-task-item": "^3.11.0",
        "@tiptap/extension-task-list": "^3.11.0",
        "@tiptap/extension-text-align": "^3.11.0",
        "@tiptap/extension-text-style": "^3.11.0",
        "@tiptap/pm": "^3.11.0",
        "@tiptap/starter-kit": "^3.11.0",
        "class-variance-authority": "^0.7.1",
        "highlight.js": "^11.11.1",
        "lucide-angular": "^0.556.0",
        "luxon": "^3.7.2",
        "postcss": "^8.5.6",
        "prosemirror-state": "^1.4.4",
        "remixicon": "^4.7.0",
        "rxjs": "~7.8.2",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.17",
        "tslib": "^2.8.1",
        "uuid": "^13.0.0",
        "zone.js": "~0.15.1"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^21.1.0",
        "@angular-eslint/eslint-plugin": "^21.1.0",
        "@angular-eslint/eslint-plugin-template": "^21.1.0",
        "@angular-eslint/schematics": "^21.1.0",
        "@angular-eslint/template-parser": "^21.1.0",
        "@angular/build": "^21.0.2",
        "@angular/cli": "^21.0.2",
        "@angular/compiler-cli": "^21.0.3",
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.39.1",
        "@fortawesome/fontawesome-free": "^7.1.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/highlightjs": "^10.1.0",
        "@types/jasmine": "~5.1.13",
        "@types/luxon": "^3.7.1",
        "@typescript-eslint/eslint-plugin": "^8.49.0",
        "@typescript-eslint/parser": "^8.49.0",
        "eslint": "^9.39.1",
        "jasmine-core": "~5.13.0",
        "karma": "~6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.1",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "ng-packagr": "^21.0.0",
        "postcss": "^8.5.6",
        "prettier": "^3.7.4",
        "ts-morph": "^27.0.2",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3"
    }
}